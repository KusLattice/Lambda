rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Verifica si es admin leyendo Firestore
    function isAdmin() {
      return request.auth != null && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['SuperAdmin', 'Admin'];
    }

    // 1. Carpeta de Actualizaciones OTA (Solo lectura pública)
    match /apk_updates/{allPaths=**} {
      allow read: if true;
      allow write: if false; 
    }

    match /ota_updates/{allPaths=**} {
      allow read: if true;
      allow write: if false; 
    }

    match /updates/{allPaths=**} {
      allow read: if true;
      allow write: if false; 
    }

    // 2. Archivos de usuarios (fotos de perfil, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 3. Fallback general (Seguro)
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Permitimos borrar cosas en rutas no específicas solo a Admins
      allow update, delete: if isAdmin(); 
    }
  }
}
