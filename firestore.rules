rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // Funciones Auxiliares
    // ==========================================
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SuperAdmin', 'Admin'];
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSender(senderId) {
      return request.auth != null && request.auth.uid == senderId;
    }

    // ==========================================

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
      allow update, delete: if isAdmin();

      match /profile_visitors/{visitorId} {
        allow read, write: if request.auth != null;
      }
      
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /messages/{messageId} {
      allow get: if request.auth != null &&
        (request.auth.uid == resource.data.senderId ||
         request.auth.uid == resource.data.receiverId ||
         isAdmin());

      allow list: if request.auth != null &&
        (request.auth.uid == resource.data.senderId ||
         request.auth.uid == resource.data.receiverId ||
         isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.senderId ||
         request.auth.uid == resource.data.receiverId ||
         isAdmin());
    }

    match /contact_requests/{requestId} {
      allow read, write: if request.auth != null;
    }

    match /admin_requests/{requestId} {
      allow create: if isSender(request.resource.data.senderId);
      allow get: if isSender(resource.data.senderId) || isAdmin();
      allow list, update, delete: if isAdmin();
    }

    match /nicknames/{nickname} {
      allow read, write: if request.auth != null;
    }

    // Protocolo de Random Board (Anónimo)
    match /random_board/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin()); 

      match /replies/{replyId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.userId || isAdmin());
        allow update: if false; 
      }
    }

    match /recycle_bin_posts/{postId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.deletedBy || isAdmin());
    }

    match /market_items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId || request.auth.uid == resource.data.vendorId || isAdmin());

      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
        allow update: if false; 
      }
    }

    match /food_tracker/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
        allow update: if false;
      }

      match /ratings/{userId} {
        allow read: if request.auth != null;
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /lodging_tracker/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
        allow update: if false;
      }

      match /ratings/{userId} {
        allow read: if request.auth != null;
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /chambas/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
         allow read, create: if request.auth != null;
         allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
         allow update: if false;
      }
    }

    match /hacks_vault/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId || isAdmin());
      
      match /comments/{commentId} {
         allow read, create: if request.auth != null;
         allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
         allow update: if false;
      }
    }

    match /nave_vault/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null &&
          (request.auth.uid == resource.data.authorId || isAdmin());
        allow update: if false;
      }
    }

    match /metadata/{docId} {
      allow read: if request.auth != null;
      // Counters de Random Board (randomCount, lastPostId, totalVisits):
      // cualquier user autenticado puede crear/incrementar via tx.set(merge).
      // Solo admins pueden borrar docs de metadata.
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    match /app_stats/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /semantic_index/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && 
        (request.auth.uid == resource.data.targetUserId || isAdmin());
      allow create: if request.auth != null;
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.targetUserId || isAdmin());
    }

    match /fiber_cut_reports/{reportId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isAdmin()); 
    }

    match /telecom_news/{newsId} {
      allow read: if request.auth != null;
      // Permitimos create para el seed de fallbacks, o si es Admin. 
      // Idealmente solo admin, pero por la lógica actual de seeding, permitimos la creación si el usuario expulsa un seed local.
      allow write: if request.auth != null;
    }
  }
}
